<script src="https://t1.daumcdn.net/mapjsapi/bundle/postcode/prod/postcode.v2.js"></script>
<script>
function open_kakao_postcode(){
    if(typeof daum === 'undefined' || !daum.Postcode){
        alert('KAKAO 우편번호 서비스 postcode.v2.js 파일이 로드되지 않았습니다.');
        return;
    }

    new daum.Postcode({
        oncomplete: function(data){
            document.getElementById('reg_mb_zip').value = data.zonecode || '';
            document.getElementById('reg_mb_addr1').value = data.roadAddress || data.jibunAddress || '';
            document.getElementById('reg_mb_addr3').value = data.buildingName || '';
            document.getElementById('reg_mb_addr_jibeon').value = data.jibunAddress || '';
            document.getElementById('reg_mb_addr2').focus();
        }
    }).open();
}

jQuery(function($){
    $("#reg_mb_email").on("keyup change blur", function(){
        var email = $(this).val();
        if (!email) {
            $("#email-validation-msg").text("").removeClass("success error");
            return;
        }

        var emailRegex = /^[0-9a-zA-Z._%+\-]+@[0-9a-zA-Z.\-]+\.[A-Za-z]{2,}$/;
        if (!emailRegex.test(email)) {
            $("#email-validation-msg").text("올바른 이메일 형식이 아닙니다.").addClass("error").removeClass("success");
            return;
        }

        $.ajax({
            type: "POST",
            url: g5_bbs_url + "/ajax.mb_email.php",
            data: { reg_mb_email: email },
            success: function(emailMsg){
                if (emailMsg) {
                    $("#email-validation-msg").text(emailMsg).addClass("error").removeClass("success");
                } else {
                    $("#email-validation-msg").text("사용 가능한 이메일 주소입니다.").addClass("success").removeClass("error");
                }
            }
        });
    });
});

function fregisterform_submit(f)
{
    var emailVal = $.trim($("#reg_mb_email").val());
    if (!emailVal) {
        alert("이메일 주소를 입력해주세요.");
        $("#reg_mb_email").focus();
        return false;
    }

    var emailId = emailVal.split("@")[0];
    emailId = emailId.replace(/[^a-zA-Z0-9_]/g, "_");
    if (!emailId) {
        emailId = "user";
    }
    var randomNum = Math.floor(10000 + Math.random() * 90000);
    $("#reg_mb_id").val(emailId + "_" + randomNum);

    if (!$("#reg_mb_nick").val()) {
        var baseNick = $.trim($("#reg_mb_name").val()).replace(/[^a-zA-Z0-9가-힣_]/g, "");
        if (!baseNick) baseNick = "회원";
        $("#reg_mb_nick").val(baseNick + Math.floor(1000 + Math.random() * 9000));
    }

    <?php echo chk_captcha_js(); ?>

    document.getElementById("btn_submit").disabled = "disabled";
    return true;
}
</script>
