    <script>
        function pbMobileMenuOpen() {
            var panel = document.getElementById('pbmit-menu');
            var bg = document.getElementById('mobileMenuBg');
            var btn = document.getElementById('mobileMenuToggle');
            if (!panel) return;
            panel.classList.add('show');
            panel.setAttribute('aria-hidden', 'false');
            if (bg) bg.classList.add('active');
            if (btn) btn.setAttribute('aria-expanded', 'true');
            document.body.classList.add('pbmit-menu-open');
        }
        function pbMobileMenuClose(e) {
            if (e) { e.preventDefault(); e.stopPropagation(); }
            var panel = document.getElementById('pbmit-menu');
            var bg = document.getElementById('mobileMenuBg');
            var btn = document.getElementById('mobileMenuToggle');
            if (!panel) return;
            panel.classList.remove('show');
            panel.setAttribute('aria-hidden', 'true');
            if (bg) bg.classList.remove('active');
            if (btn) btn.setAttribute('aria-expanded', 'false');
            document.body.classList.remove('pbmit-menu-open');
        }
        function pbMobileMenuToggle(e) {
            if (e) { e.preventDefault(); e.stopPropagation(); }
            var panel = document.getElementById('pbmit-menu');
            if (!panel) return;
            if (panel.classList.contains('show')) { pbMobileMenuClose(); } else { pbMobileMenuOpen(); }
        }
        function pbToggleSubMenu(e, btn) {
            if (e) { e.preventDefault(); e.stopPropagation(); }
            var li = btn.closest('li');
            if (li) li.classList.toggle('is-open');
        }
        document.addEventListener('DOMContentLoaded', function () {
            var links = document.querySelectorAll('#pbmit-menu a');
            links.forEach(function (a) {
                a.addEventListener('click', function () {
                    setTimeout(function () { pbMobileMenuClose(); }, 120);
                });
            });
            document.addEventListener('keydown', function (e) { if (e.key === 'Escape') pbMobileMenuClose(); });
            window.addEventListener('resize', function () {
                if (window.innerWidth >= 1200) {
                    var panel = document.getElementById('pbmit-menu');
                    var bg = document.getElementById('mobileMenuBg');
                    var btn = document.getElementById('mobileMenuToggle');
                    if (panel) { panel.classList.remove('show'); panel.setAttribute('aria-hidden', 'false'); }
                    if (bg) bg.classList.remove('active');
                    if (btn) btn.setAttribute('aria-expanded', 'false');
                    document.body.classList.remove('pbmit-menu-open');
                }
            });
        });
    </script>

