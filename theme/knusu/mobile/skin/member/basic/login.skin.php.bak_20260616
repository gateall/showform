        <input type="hidden" name="url" value="<?php echo $login_url ?>">

            <a class="login-social login-social-kakao" href="<?php echo $kakao_login_url; ?>">
                <span class="login-social-icon" aria-hidden="true">
                    <img src="<?php echo G5_IMG_URL; ?>/kakao.png" alt="">
                </span>
                <span>카카오로 3초만에 시작하기</span>
            </a>

            <div class="login-divider"><span>또는 이메일로 로그인</span></div>

            <div class="login-field">
                <label for="login_id">이메일 주소</label>
                <input type="text" name="mb_id" id="login_id" required class="frm_input required" maxlength="100" placeholder="이메일 주소">
