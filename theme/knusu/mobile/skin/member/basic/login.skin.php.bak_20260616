<div id="mb_login" class="login-page">
    <div class="login-card">
        <div class="login-top">
            <a href="#login" class="login-tab is-active">로그인</a>
            <a href="<?php echo G5_BBS_URL ?>/register.php" class="login-tab">회원가입</a>
