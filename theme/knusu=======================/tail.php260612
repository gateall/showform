<style>
#ft{background:#f4f5f7;border-top:1px solid #e5e7eb;padding:0}
#ft .kfooter-contact{position:relative;overflow:hidden;background:linear-gradient(135deg,#1f9d55 0%,#39b46c 32%,#4ccf88 100%);color:#fff}
#ft .kfooter-contact:before{content:"";position:absolute;inset:-160px -120px auto auto;width:340px;height:340px;border-radius:50%;background:radial-gradient(circle,rgba(255,255,255,.18) 0,rgba(255,255,255,0) 70%);pointer-events:none}
#ft .kfooter-contact:after{content:"";position:absolute;left:-120px;bottom:-180px;width:360px;height:360px;border-radius:50%;background:radial-gradient(circle,rgba(255,255,255,.12) 0,rgba(255,255,255,0) 72%);pointer-events:none}
#ft .kfooter-contact__inner{max-width:1280px;margin:0 auto;padding:36px 20px 30px;box-sizing:border-box}
#ft .kfooter-contact__layout{display:grid;grid-template-columns:minmax(0,1fr) minmax(360px, 520px);align-items:start;gap:24px}
#ft .kfooter-contact__eyebrow{margin:0 0 10px;font-size:13px;font-weight:900;letter-spacing:.22em;opacity:.92;text-transform:uppercase}
#ft .kfooter-contact__title{margin:0;font-size:31px;line-height:1.16;font-weight:900;letter-spacing:-.04em;text-wrap:balance}
#ft .kfooter-contact__desc{margin:12px 0 0;font-size:16px;line-height:1.65;opacity:.96;max-width:34em}
#ft .kfooter-contact__actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:20px}
#ft .kfooter-contact__btn{display:inline-flex;align-items:center;justify-content:center;min-width:200px;height:58px;padding:0 24px;border-radius:18px;font-size:16px;font-weight:900;text-decoration:none;box-sizing:border-box;box-shadow:0 14px 30px rgba(0,0,0,.14);transition:transform .2s ease,box-shadow .2s ease,background .2s ease,filter .2s ease}
#ft .kfooter-contact__btn:hover{transform:translateY(-3px);box-shadow:0 18px 34px rgba(0,0,0,.18);filter:saturate(1.03)}
#ft .kfooter-contact__btn--phone{background:#f2d86d;color:#0f172a}
#ft .kfooter-contact__btn--online{background:#fff;color:#166534}
#ft .kfooter-contact__form{position:relative;background:rgba(255,255,255,.14);border:1px solid rgba(255,255,255,.28);border-radius:26px;padding:24px;box-shadow:0 22px 44px rgba(0,0,0,.14);backdrop-filter:blur(16px);overflow:hidden}
#ft .kfooter-contact__form:before{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(255,255,255,.10),rgba(255,255,255,0));pointer-events:none}
#ft .kfooter-contact__form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;position:relative;z-index:1}
#ft .kfooter-contact__field{display:flex;flex-direction:column;gap:8px}
#ft .kfooter-contact__field--full{margin-top:12px;position:relative;z-index:1;grid-column:1 / -1}
#ft .kfooter-contact__field label{font-size:13px;font-weight:900;letter-spacing:-.02em;color:#fff;opacity:.98}
#ft .kfooter-contact__field input,
#ft .kfooter-contact__field textarea{
  width:100%;
  border:1px solid rgba(15,87,214,.16);
  border-top-color:rgba(255,255,255,.95);
  border-left-color:rgba(255,255,255,.90);
  border-radius:18px;
  background:
    linear-gradient(180deg, rgba(255,255,255,.99) 0%, rgba(248,251,255,.98) 100%);
  color:#0f172a;
  padding:16px 16px;
  font-size:15px;
  line-height:1.45;
  box-sizing:border-box;
  outline:none;
  min-height:50px;
  box-shadow:
    0 12px 26px rgba(15,23,42,.08),
    inset 0 1px 0 rgba(255,255,255,.92),
    inset 0 -1px 0 rgba(15,87,214,.04);
  transition:border-color .2s ease, box-shadow .2s ease, transform .2s ease, background .2s ease;
}
#ft .kfooter-contact__field textarea{min-height:108px;resize:vertical}
#ft .kfooter-contact__field input::placeholder,
#ft .kfooter-contact__field textarea::placeholder{color:#94a3b8;font-weight:600}
#ft .kfooter-contact__field input:hover,
#ft .kfooter-contact__field textarea:hover{border-color:rgba(15,87,214,.28);box-shadow:0 14px 28px rgba(15,23,42,.10), inset 0 1px 0 rgba(255,255,255,.94), inset 0 -1px 0 rgba(15,87,214,.05)}
#ft .kfooter-contact__field input:focus,
#ft .kfooter-contact__field textarea:focus{border-color:#0f57d6;box-shadow:0 0 0 4px rgba(15,87,214,.16), 0 16px 30px rgba(15,23,42,.12), inset 0 1px 0 rgba(255,255,255,.95);background:#fff;transform:translateY(-1px)}
#ft .kfooter-contact__field input:focus::placeholder,
#ft .kfooter-contact__field textarea:focus::placeholder{color:#cbd5e1}
#ft .kfooter-contact__privacy{margin-top:10px;position:relative;z-index:1}
#ft .kfooter-contact__privacy-toggle{display:inline-flex;align-items:center;justify-content:space-between;gap:10px;width:100%;min-height:52px;padding:0 16px;border:1px solid rgba(255,255,255,.28);border-radius:16px;background:rgba(15,23,42,.20);color:#fff;font-size:14px;font-weight:900;cursor:pointer;box-shadow:0 10px 22px rgba(0,0,0,.10)}
#ft .kfooter-contact__privacy-toggle:after{content:"▾";font-size:12px;opacity:.9}
#ft .kfooter-contact__privacy.is-open .kfooter-contact__privacy-toggle:after{content:"▴"}
#ft .kfooter-contact__privacy-panel{margin-top:4px;padding:12px;border-radius:18px;background:rgba(255,255,255,.95);border:1px solid rgba(255,255,255,.5);color:#1f2937;box-shadow:0 12px 26px rgba(0,0,0,.12)}
#ft .kfooter-contact__privacy-note{margin:0 0 12px;font-size:13px;line-height:1.7;color:#374151}
#ft .kfooter-contact__privacy-panel .kfooter-contact__agree{color:#1f2937}
#ft .kfooter-contact__privacy-panel .kfooter-contact__agree-sub{opacity:.78}
#ft .kfooter-contact__privacy-panel .kfooter-contact__agree{padding:12px 14px;border-radius:16px;border:1px solid #dbe3ee;background:#f8fafc}
#ft .kfooter-contact__privacy-panel .kfooter-contact__agree input{appearance:auto;-webkit-appearance:checkbox;display:inline-block !important;visibility:visible !important;opacity:1 !important;width:20px;height:20px;min-width:20px;min-height:20px;margin:2px 0 0;accent-color:#0f57d6}
#ft .kfooter-contact__privacy-panel .kfooter-contact__agree.is-checked{border-color:#0f57d6;background:#eef5ff;box-shadow:0 0 0 3px rgba(15,87,214,.12) inset}
#ft .kfooter-contact__footer{display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:12px;margin-top:14px;position:relative;z-index:1}
#ft .kfooter-contact__agree{display:flex;align-items:flex-start;gap:10px;color:#fff;font-size:13px;line-height:1.55}
#ft .kfooter-contact__agree input{width:18px;height:18px;margin:2px 0 0;accent-color:#0f172a;flex:0 0 18px}
#ft .kfooter-contact__agree-text{display:block}
#ft .kfooter-contact__agree-main{display:block;font-weight:900;font-size:14px;letter-spacing:-.02em}
#ft .kfooter-contact__agree-sub{display:block;margin-top:2px;opacity:.92}
#ft .kfooter-contact__submit{display:inline-flex;align-items:center;justify-content:center;min-width:190px;height:56px;width:calc(100% - 24px);padding:0 24px;border:0;border-radius:12px;background:linear-gradient(135deg,#0b1b36 0%,#0f57d6 55%,#2563eb 100%);color:#fff;font-size:15px;font-weight:900;letter-spacing:-.02em;cursor:pointer;box-shadow:0 16px 30px rgba(15,87,214,.34), inset 0 1px 0 rgba(255,255,255,.18);text-shadow:0 1px 1px rgba(0,0,0,.28);transition:transform .2s ease,box-shadow .2s ease,filter .2s ease,background .2s ease;margin:10px 12px 6px}
#ft .kfooter-contact__submit:hover{transform:translateY(-2px);filter:saturate(1.06);box-shadow:0 20px 36px rgba(15,87,214,.42), inset 0 1px 0 rgba(255,255,255,.18)}
#ft .kfooter{max-width:1280px;margin:0 auto;padding:36px 20px 34px;box-sizing:border-box}
#ft .kfooter-inner{display:flex;align-items:flex-start;gap:34px}
#ft .kfooter-logo{flex:0 0 150px}
#ft .kfooter-logo img{display:block;max-width:100%;height:auto}
#ft .kfooter-text{flex:1;min-width:0}
#ft .kfooter-menu{display:flex;flex-wrap:wrap;gap:15px;list-style:none;padding:0;margin:0 0 15px;font-weight:800;color:#333}
#ft .kfooter-menu a{color:#333;text-decoration:none}
#ft .kfooter-links{display:flex;flex-wrap:wrap;gap:8px;margin:0 0 14px}
#ft .kfooter-links a{display:inline-flex;align-items:center;justify-content:center;min-height:36px;padding:0 14px;border-radius:999px;border:1px solid #d8dde6;background:#fff;color:#334155;text-decoration:none;font-size:13px;font-weight:800}
#ft .kfooter-links a:hover{background:#0f57d6;border-color:#0f57d6;color:#fff}
#ft .kfooter-info{display:flex;flex-wrap:wrap;align-items:center;gap:10px 14px;margin:0;color:#6b7280;font-size:15px;line-height:1.8;word-break:keep-all}
#ft .kfooter-info .bar{color:#c4c4c4}
#ft .kfooter-copy{margin:12px 0 0;color:#7c7c7c;font-size:15px;line-height:1.7;letter-spacing:.2px}
.kfooter-bottom{display:flex;align-items:flex-end;justify-content:space-between;gap:16px;margin-top:20px}
.kfooter-bottom__text{flex:1;min-width:0}
.kfooter-top-btn{display:inline-flex;align-items:center;justify-content:center;width:52px;height:52px;border:0;border-radius:50%;background:#0f172a;color:#fff;font-size:18px;font-weight:900;cursor:pointer;box-shadow:0 10px 24px rgba(0,0,0,.14);transition:transform .2s ease,background .2s ease}
.kfooter-top-btn:hover{transform:translateY(-3px);background:#0f57d6}
.mobile_footer_btns{display:none}
.mobile_cta_bar{display:none}
.kn-pc-quick,.kn-pc-admin{display:none}
body{padding-bottom:70px}
