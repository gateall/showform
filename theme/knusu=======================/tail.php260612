  .mobile_footer_btns a{display:inline-flex;align-items:center;justify-content:center;min-width:68px;height:34px;padding:0 10px;border-radius:6px;background:#fff;color:#111827;font-size:13px;font-weight:700;text-decoration:none;box-sizing:border-box}
  .mobile_footer_btns a:hover{background:#2563eb;color:#fff}
  .mobile_cta_bar{display:flex;position:fixed;left:0;right:0;bottom:0;z-index:100000;gap:8px;padding:10px 12px;background:rgba(10,18,28,.96);box-shadow:0 -10px 30px rgba(0,0,0,.16);backdrop-filter:blur(8px);box-sizing:border-box;transition:transform .25s ease,opacity .25s ease}
  .mobile_cta_bar a,
  .mobile_cta_bar button{flex:1 1 0;display:flex;align-items:center;justify-content:center;min-height:54px;padding:0 12px;border-radius:14px;font-size:14px;font-weight:900;text-decoration:none;box-sizing:border-box;white-space:nowrap;border:0;cursor:pointer;min-width:0}
  .mobile_cta_call{background:#edda7d;color:#0a182b !important}
  .mobile_cta_online{background:#22c55e;color:#fff !important}
