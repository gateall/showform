<script>
document.addEventListener('DOMContentLoaded', function () {
    var quickTopBtn = document.getElementById('knPcQuickTop');
    if (quickTopBtn) {
        quickTopBtn.addEventListener('click', function (e) {
            e.preventDefault();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    }
    var footerTopBtn = document.getElementById('kfooterTopBtn');
    if (footerTopBtn) {
        footerTopBtn.addEventListener('click', function (e) {
            e.preventDefault();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    }

    var quickContactBtn = document.getElementById('mobileQuickContactBtn');
    var quickContactPanel = document.getElementById('mobileQuickContactPanel');
    var quickContactClose = document.getElementById('mobileQuickContactClose');
    var quickContactDim = quickContactPanel ? quickContactPanel.querySelector('.mobileQuickContactPanel__dim') : null;

    function openQuickContact() {
        if (!quickContactPanel) return;
        quickContactPanel.classList.add('is-open');
        quickContactPanel.setAttribute('aria-hidden', 'false');
        if (quickContactBtn) {
            quickContactBtn.setAttribute('aria-expanded', 'true');
        }
        document.body.classList.add('mobile-quick-contact-open');
    }

    function closeQuickContact() {
        if (!quickContactPanel) return;
        quickContactPanel.classList.remove('is-open');
        quickContactPanel.setAttribute('aria-hidden', 'true');
        if (quickContactBtn) {
            quickContactBtn.setAttribute('aria-expanded', 'false');
        }
        document.body.classList.remove('mobile-quick-contact-open');
    }

    if (quickContactBtn) {
        quickContactBtn.addEventListener('click', function (e) {
            e.preventDefault();
            openQuickContact();
        });
    }

    if (quickContactClose) {
        quickContactClose.addEventListener('click', function (e) {
            e.preventDefault();
            closeQuickContact();
        });
    }

    if (quickContactDim) {
        quickContactDim.addEventListener('click', function () {
            closeQuickContact();
        });
    }

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
            closeQuickContact();
        }
    });

    document.addEventListener('click', function (e) {
        var privacyToggle = e.target.closest('.kfooter-contact__privacy-toggle');
        if (privacyToggle) {
            e.preventDefault();
            var privacyWrap = privacyToggle.closest('.kfooter-contact__privacy');
            if (!privacyWrap) return;
            var privacyPanel = privacyWrap.querySelector('.kfooter-contact__privacy-panel');
            var isOpen = privacyWrap.classList.contains('is-open');
            privacyWrap.classList.toggle('is-open', !isOpen);
            privacyToggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
            if (privacyPanel) {
                privacyPanel.hidden = isOpen;
            }
        }
    });

    document.addEventListener('change', function (e) {
        if (!e.target.matches('.kfooter-contact__agree-checkbox')) return;
        var agreeWrap = e.target.closest('.kfooter-contact__agree');
        if (agreeWrap) {
            agreeWrap.classList.toggle('is-checked', e.target.checked);
        }
        var form = e.target.closest('.kfooter-contact__form');
        if (form) {
            form.classList.toggle('is-agree-checked', e.target.checked);
        }
    });

    document.addEventListener('submit', function (e) {
        var form = e.target.closest('.kfooter-contact__form');
        if (!form) return;
        var agree = form.querySelector('.kfooter-contact__agree-checkbox');
        if (!agree || agree.checked) return;
        e.preventDefault();
        var privacyWrap = form.querySelector('.kfooter-contact__privacy');
        var privacyPanel = form.querySelector('.kfooter-contact__privacy-panel');
        var privacyToggle = form.querySelector('.kfooter-contact__privacy-toggle');
        if (privacyWrap && privacyPanel) {
            privacyWrap.classList.add('is-open');
            privacyPanel.hidden = false;
            if (privacyToggle) {
                privacyToggle.setAttribute('aria-expanded', 'true');
            }
        }
        alert('개인정보 이용동의가 필요합니다.');
        if (agree) {
            agree.focus();
        }
    }, true);
});
</script>

<?php
include_once(G5_THEME_PATH.'/tail.sub.php');
