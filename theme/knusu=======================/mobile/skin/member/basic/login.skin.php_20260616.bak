#mb_login .login-tab{flex:1;text-align:center;padding:12px 8px;border-radius:999px;background:#f3f5f7;color:#667085;font-weight:700;font-size:14px;text-decoration:none}
#mb_login .login-tab.is-active{background:#111827;color:#fff}
#mb_login .login-social{display:flex;align-items:center;justify-content:center;gap:10px;width:100%;min-height:52px;border-radius:14px;background:#fee500;color:#3b1e1e;font-weight:800;font-size:15px;text-decoration:none}
#mb_login .login-social-icon img{width:20px;height:20px;display:block}
#mb_login .login-divider{position:relative;margin:16px 0;text-align:center;color:#98a2b3;font-size:13px}
#mb_login .login-divider:before{content:"";position:absolute;left:0;right:0;top:50%;height:1px;background:#e5e7eb}
#mb_login .login-divider span{position:relative;background:#fff;padding:0 10px}
#mb_login .login-field{margin-bottom:12px}
#mb_login .login-field label{display:block;margin-bottom:7px;font-size:13px;font-weight:700;color:#344054}
#mb_login .login-field .frm_input{width:100%;height:50px;border-radius:14px;border:1px solid #d0d5dd;padding:0 14px;font-size:15px;background:#fff}
#mb_login .login-password-wrap{display:flex;gap:8px;align-items:center}
#mb_login .login-password-wrap .frm_input{flex:1}
#mb_login .login-password-toggle{flex:0 0 auto;height:50px;padding:0 12px;border:1px solid #d0d5dd;border-radius:14px;background:#fff;color:#344054;font-weight:700}
#mb_login .login-submit{width:100%;height:54px;border:0;border-radius:16px;background:linear-gradient(135deg,#b8e986 0%,#7bc96f 100%);color:#fff;font-size:16px;font-weight:800;margin-top:2px}
#mb_login .login-links{display:flex;justify-content:space-between;gap:12px;margin-top:16px;font-size:13px}
